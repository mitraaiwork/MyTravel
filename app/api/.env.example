# Copy this file to .env and fill in your values
# Never commit .env to git

# Database (use local Docker for dev, Supabase for production)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mytravel

# JWT — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=

# Mapbox (account.mapbox.com)
MAPBOX_TOKEN=

# Resend (resend.com)
RESEND_API_KEY=

# Sentry (sentry.io) — optional for local dev
SENTRY_DSN=

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# App
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000"]
DEBUG=true
